# =============================================================
# PRODUCTION (cbhcloud deployment)
# =============================================================
# Copy these values into your cbhcloud deployment environment variables.
#
# PostgreSQL
POSTGRES_HOST=ducklake-catalog
POSTGRES_PORT=5432
POSTGRES_DB=ducklake
POSTGRES_ADMIN_USER=ducklake
POSTGRES_ADMIN_PASSWORD=your-admin-password
#
# Garage Admin API — port 3900 (nginx reverse proxy inside ducklake-garage)
# nginx forwards /v2/* to the internal Admin API on port 3903.
GARAGE_ADMIN_URL=http://ducklake-garage:3900
GARAGE_ADMIN_TOKEN=your-garage-admin-token
GARAGE_S3_ENDPOINT=ducklake-garage:3900
GARAGE_S3_REGION=garage
#
PORT=8080

# =============================================================
# LOCAL TESTING (SSH tunnels)
# =============================================================
# Open two tunnels before starting the app:
#
#   Terminal 1 — PostgreSQL (use 5433 to avoid conflicts with local Postgres):
#     ssh -L 5433:localhost:5432 ducklake-catalog@deploy.cloud.cbh.kth.se
#
#   Terminal 2 — Garage Admin API (direct to port 3903, bypasses nginx):
#     ssh -L 3903:localhost:3903 ducklake-garage@deploy.cloud.cbh.kth.se
#
# Get the Garage admin token:
#   ssh ducklake-garage@deploy.cloud.cbh.kth.se
#   cat /tmp/garage.toml | grep admin_token
#
# Then override these values in your local .env:
#
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5433
# GARAGE_ADMIN_URL=http://127.0.0.1:3903
# GARAGE_S3_ENDPOINT=ducklake-garage.deploy.cloud.cbh.kth.se:443
