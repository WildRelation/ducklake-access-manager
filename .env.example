# PostgreSQL admin connection (ducklake-catalog deployment)
POSTGRES_HOST=ducklake-catalog
POSTGRES_PORT=5432
POSTGRES_DB=ducklake
POSTGRES_ADMIN_USER=ducklake
POSTGRES_ADMIN_PASSWORD=your-admin-password

# Garage Admin API (ducklake-garage deployment, internal port 3903)
GARAGE_ADMIN_URL=http://ducklake-garage:3903
GARAGE_ADMIN_TOKEN=your-garage-admin-token
GARAGE_S3_ENDPOINT=https://ducklake-garage.cbh.kth.se

# App
PORT=8080
